{
  "name": "hyperguard",
  "private": true,
  "type": "module",
  "description": "HyperGuard trading app — TypeScript source bundled with esbuild for static GitHub Pages hosting.",
  "scripts": {
    "build": "esbuild src/app.ts --bundle --format=esm --target=es2020 --outfile=dist/app.js --sourcemap --log-level=warning",
    "watch": "esbuild src/app.ts --bundle --format=esm --target=es2020 --outfile=dist/app.js --sourcemap --watch",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "esbuild": "^0.24.0",
    "typescript": "^5.6.0"
  }
}
